# ==========================================================
# Application
# ==========================================================
APP_NAME=AI Career Counselor Platform
APP_VERSION=1.0.0
API_PREFIX=/api/v1

HOST=0.0.0.0
PORT=8000

ENVIRONMENT=production

LOG_LEVEL=INFO

# ==========================================================
# LLM
# ==========================================================
LLM_PROVIDER=groq
GROQ_API_KEY=YOUR_GROQ_API_KEY

GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# ==========================================================
# RAG
# ==========================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=100

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

VECTOR_DB_DIR=data/vector_db